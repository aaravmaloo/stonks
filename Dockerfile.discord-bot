FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/stanks-discord-bot ./cmd/stanks-discord-bot

FROM gcr.io/distroless/static-debian12:nonroot
WORKDIR /app
COPY --from=build /out/stanks-discord-bot /app/stanks-discord-bot
ENTRYPOINT ["/app/stanks-discord-bot"]
